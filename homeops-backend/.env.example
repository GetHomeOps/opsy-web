# Database
DATABASE_URL=postgresql:///opsy

# JWT
SECRET_KEY=your-secret-key

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
APP_BASE_URL=http://localhost:5173
# STRIPE_SUCCESS_URL=  # optional, derived from APP_BASE_URL
# STRIPE_CANCEL_URL=   # optional
# BILLING_MOCK_MODE=true  # set for local dev without Stripe

# Optional: Price IDs for seed (JSON)
# STRIPE_PRICE_IDS={"homeowner_maintain_month":"price_xxx",...}

# Property data lookup (RentCast)
RENTCAST_API_KEY=your-rentcast-api-key

# Email (AWS SES)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=HomeOps
# Optional: separate credentials for SES
# AWS_SES_REGION=us-east-1
# AWS_SES_ACCESS_KEY_ID=
# AWS_SES_SECRET_ACCESS_KEY=
