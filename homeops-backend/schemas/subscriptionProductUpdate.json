{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "targetRole": {"type": "string", "enum": ["homeowner", "agent"]},
    "price": {"type": "number", "minimum": 0},
    "billingInterval": {"type": "string", "enum": ["month", "year"]},
    "maxProperties": {"type": "integer", "minimum": 0},
    "maxContacts": {"type": "integer", "minimum": 0},
    "maxViewers": {"type": "integer", "minimum": 0},
    "maxTeamMembers": {"type": "integer", "minimum": 0},
    "aiTokenMonthlyQuota": {"type": "integer", "minimum": 0},
    "code": {"type": "string"},
    "sortOrder": {"type": "integer", "minimum": 0},
    "trialDays": {"type": ["integer", "null"], "minimum": 0},
    "stripeProductId": {"type": "string"},
    "stripePriceId": {"type": "string"},
    "isActive": {"type": "boolean"},
    "limits": {"type": "object"},
    "prices": {"type": "object"}
  },
  "additionalProperties": true
}
