# Backend API (local dev)
# VITE_BASE_URL=http://localhost:3000

# GA4 — set only on deployed builds (e.g. Railway). Leave unset locally so dev traffic is not tracked.
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: GA4 DebugView on staging/preview builds that already define VITE_GA_MEASUREMENT_ID
# VITE_GA_DEBUG=true
